PROJECT_NAME="Road Damage Analytics Engine"
API_V1_STR="/api/v1"
DATABASE_URL="sqlite:///./road_damage.db"

JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

BACKEND_BASE_URL="http://localhost:8000"
FRONTEND_URL="http://localhost:5173"

# --- Brevo transactional email API (for OTP verification emails) ---
# Render's free tier blocks outbound SMTP ports, so we use Brevo's HTTPS
# API instead. 1. Sign up free at https://www.brevo.com (300 emails/day).
# 2. Settings -> Senders, Domains, IPs -> Senders -> Add a sender (any
#    email you own works, e.g. your Gmail) and verify it via the code
#    Brevo emails you. 3. Account menu -> SMTP & API -> API Keys ->
#    Generate a new API key and paste it below.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME="Road Damage AI"

OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=20